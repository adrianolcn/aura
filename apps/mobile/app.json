{
  "expo": {
    "name": "AURA",
    "slug": "aura-mobile",
    "scheme": "aura",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": ["ios", "android", "web"],
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1c1917"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
