{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @aura/web dev",
    "dev:mobile": "pnpm --filter @aura/mobile start",
    "test": "node scripts/prepare-test-dist.cjs && tsc -p tsconfig.tests.json && node .test-dist/scripts/test-runner.js",
    "test:integration": "pnpm test",
    "test:e2e": "playwright test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset --local",
    "db:status": "supabase status",
    "db:lint": "supabase db lint",
    "functions:serve": "supabase functions serve --env-file supabase/functions/.env.local",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@aura/config": "workspace:*",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  }
}
